# ============================================================
# DocJuris — Configurações do Backend
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Porta do servidor (padrão: 3001)
PORT=3001

# URL do frontend para CORS
FRONTEND_URL=http://localhost:5173

# Chave secreta para JWT — TROQUE em produção!
JWT_SECRET=docjuris-troque-esta-chave-em-producao-2024

# ---- OBRIGATÓRIO: Anthropic API ----
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ---- Email (opcional em desenvolvimento) ----
# Sem estas variáveis, usa Ethereal (email de teste) — preview via URL no console
# Para Gmail: use senha de app (https://support.google.com/accounts/answer/185833)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seuemail@gmail.com
# SMTP_PASS=suaSenhaDeApp

# Nome exibido como remetente dos emails
# SENDER_NAME=Andreia Machado Advocacia
